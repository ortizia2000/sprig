# Copy to .env for local runs. In production these live as GitHub Actions secrets.
# NEVER commit real tokens.

# --- Meta (Instagram + Facebook share one Page access token) ---
META_ACCESS_TOKEN=          # Page access token (ideally a never-expiring System User token)
IG_USER_ID=17841434173594422   # @myceliumai.co Instagram business id
FB_PAGE_ID=                 # Mycelium AI Facebook Page id

# --- LinkedIn (optional, needs its own app + Community Management API approval) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# --- Where Instagram fetches images from (raw GitHub by default) ---
MEDIA_BASE_URL=https://raw.githubusercontent.com/ortizia2000/sprig/main/content/media
